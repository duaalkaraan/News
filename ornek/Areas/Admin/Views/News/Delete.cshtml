@model ornek.Models.News

<h2>هل تريد حذف هذا الخبر؟ </h2>
<p>@Model.Title</p>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />    
    <button type="submit">حذف</button>
    <a asp-area="Admin" asp-controller="News" asp-action="Index">إلغاء</a>
</form>