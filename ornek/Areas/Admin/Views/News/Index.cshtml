@using ornek.Areas.Admin.Dtos.News
@model GetAlllNewsWithStatistics


<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-newspaper"></i></div>
            <div>
                <div class="stat-value">@Model.TotalCount</div>
                <div class="stat-label">إجمالي الأخبار</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="stat-value">@Model.PublishedNewsCount</div>
                <div class="stat-label">منشورة</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-tags"></i></div>
            <div>
                <div class="stat-value">@Model.CategoryCount</div>
                <div class="stat-label">التصنيفات</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="fas fa-paper-plane"></i></div>
            <div>
                <div class="stat-value">@Model.PendingNewsCount</div>
                <div class="stat-label">طلبات النشر</div>
            </div>
        </div>
    </div>
</div>






<form asp-area="Admin" asp-controller="News" asp-action="Index" method="get" class="d-flex mb-3">
    <input type="text" name="q" value="@Context.Request.Query["q"]" class="form-control me-2"
           placeholder="ابحث عن خبر" style="width:300px;" />
    <button type="submit" class="btn"
            style="background-color: var(--blue-main); color:white;">
        <i class="fas fa-search"></i> بحث
    </button>
</form>


<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">الأخبار</h2>

    <a asp-area="Admin" asp-controller="News" asp-action="Create" class="btn"
           style="background-color: var(--blue-main); color: white; border-radius: 8px; font-weight: 600;">
        + إضافة خبر جديد
    </a>
</div>


