<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>العنوان</th>
            <th>المحتوى</th>
            <th>التصنيف</th>
            <th>التاريخ</th>
            <th>الصور</th>
            <th>الإجراءات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var news in Model)
        {
            <tr>
                <td>@news.Id</td>
                <td>
                    <a href="#" class="text-decoration-none"
                           data-bs-toggle="modal"
                           data-bs-target="#modal-@news.Id">
                        @news.Title
                    </a>
                </td>
                <td>
                   @news.Content.Substring(0,30)...
                </td>
                <td><span class="badge bg-secondary">@news.CategoryName</span></td>
                <td>@news.CreatedAt.ToShortDateString()</td>
                <td>
                    @if (news.Images != null && news.Images.Any())
                    {
                        @foreach (var img in news.Images.Take(2))
                        {
                            <img src="@img" width="50" height="50" class="rounded me-1 object-fit-cover" />
                        }
                        @if (news.Images.Count > 2)
                        {
                            <span class="badge bg-primary">+@(news.Images.Count - 2)</span>
                        }
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@news.Id" class="btn btn-sm btn-warning">تعديل</a>
                    <a asp-action="Delete" asp-route-id="@news.Id" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
        }
       
    </tbody>
</table>


@foreach (var news in Model)
{
    <div class="modal fade" id="modal-@news.Id">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@news.Title</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>@news.Content</p>
                    <div class="d-flex flex-wrap gap-2">
                        @if (news.Images != null)
                        {
                            @foreach (var img in news.Images)
                            {
                                <img src="@img" width="150" height="150" class="rounded object-fit-cover" />
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}





