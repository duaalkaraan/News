<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <table class="table table-hover mb-0">
        <thead style="background-color: var(--blue-dark); color: white;">
            <tr>
                <th>#</th>
                <th>العنوان</th>
                <th>المحتوى</th>
                <th>التصنيف</th>
                <th>التاريخ</th>
                <th>الصور</th>
                <th>الحالة</th>
                <th>الإجراءات</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var news in Model.PublishedNewsList)
            {
                <tr>
                    <td class="text-muted">@news.Id</td>
                    <td>
                        <a href="#" class="text-decoration-none fw-600"
                               style="color: var(--blue-main);"
                               data-bs-toggle="modal"
                               data-bs-target="#modal-@news.Id">
                            @news.Title
                        </a>
                    </td>
                    <td class="text-muted">@(news.Content.Length > 30 ? news.Content.Substring(0, 30) : news.Content)...</td>
                    <td>
                        <span class="badge" style="background-color: var(--blue-mid);">
                            @news.CategoryName
                        </span>
                    </td>
                    <td class="text-muted">@news.CreatedAt.ToShortDateString()</td>
                    <td>
                        @if (news.Images != null && news.Images.Any())
                        {
                            @foreach (var img in news.Images.Take(2))
                            {
                                <img src="@img" width="50" height="50" class="rounded me-1 object-fit-cover" />
                            }
                            @if (news.Images.Count > 2)
                            {
                                <span class="badge" style="background-color: var(--blue-main);">
                                    +@(news.Images.Count - 2)
                                </span>
                            }
                        }
                    </td>
                    <td>
                        <span class="badge" style="background-color: @(news.Status == "Approved" ? "red" : news.Status == "Pending" ? "orange" : "green")">
                            @news.Status
                        </span>
                    </td>
                    <td>

                        <a asp-action="Edit" asp-route-id="@news.Id"
                           class="btn btn-sm"
                           style="background-color: var(--blue-mid); color: white;">تعديل</a>
                        <a asp-action="Delete" asp-route-id="@news.Id"
                           class="btn btn-sm btn-danger">حذف</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="mt-4 d-flex justify-content-center gap-2">

@if (Model.PublishedNewsList.HasPreviousPage)
{
        <a asp-action="Index" asp-route-q="@Context.Request.Query["q"]" asp-route-pageIndex="@(Model.PublishedNewsList.PageIndex - 1)" class="btn btn-secondary">
            السابق
        </a>
}

@for (int i = 1; i <= Model.PublishedNewsList.TotalPages; i++)
{
        <a asp-action="Index" asp-route-q="@Context.Request.Query["q"]" asp-route-pageIndex="@i"
               class="btn @(i == Model.PublishedNewsList.PageIndex ? "btn-primary" : "btn-outline-secondary")">
            @i
        </a>
}

@if (Model.PublishedNewsList.HasNextPage)
{
        <a asp-action="Index" asp-route-q="@Context.Request.Query["q"]" asp-route-pageIndex="@(Model.PublishedNewsList.PageIndex + 1)" class="btn btn-secondary">
            التالي
        </a>
}

</div>



@foreach (var news in Model.PublishedNewsList)
{
    <div class="modal fade" id="modal-@news.Id">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 rounded-3 overflow-hidden">
                <div class="modal-header" style="background-color: var(--blue-dark); color: white;">
                    <h5 class="modal-title">@news.Title</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="background-color: var(--blue-bg);">
                    <p>@news.Content</p>
                    <div class="d-flex flex-wrap gap-2">
                        @if (news.Images != null)
                        {
                            @foreach (var img in news.Images)
                            {
                                <img src="@img" width="150" height="150" class="rounded object-fit-cover" />
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}




