@model List<ornek.ViewModels.UserRolesViewModel>
@{
    ViewData["Title"] = "ادارة المستخدمين";
}
<h1>ادارة المستخدمين</h1>
<table class="table table-striped">
    <thead>
        <tr>
         
            <th>Email</th>
            <th>Roles</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
               
                <td>@user.Email</td>
                <td>@string.Join(" , ", user.Roles)</td>
                <td>
                    <a class="btn btn-primary" asp-controller="Users" asp-action="ManageRole" asp-route-userId="@user.UserId">ادارة الصلاحيات</a>
                </td>
            </tr>
        }
    </tbody>
</table>