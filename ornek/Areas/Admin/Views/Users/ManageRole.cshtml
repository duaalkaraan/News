@model List<ornek.ViewModels.ManageUserRolesViewModel>
@{
    ViewData["Title"] = "Manage";
}

<h2 class="section-title mb-4">إدارة صلاحيات المستخدم</h2>

<div class="admin-table-card p-4">
    <p class="mb-4" style="color:#6b7280">
        اضافة/إزالة الصلاحيات للمستخدم / @ViewBag.UserName
    </p>



<form method="post">
  
            @for (int i = 0; i < Model.Count; i++)
            {
                <div class="form-check m-1">
                    <input type="hidden" asp-for="@Model[i].RoleId" />
                    <input type="hidden" asp-for="@Model[i].RoleName" />
                    <input asp-for="@Model[i].Selected" class="form-check-input" />
                    <label class="form-check-label" asp-for="@Model[i].Selected">
                        @Model[i].RoleName
                    </label>
                </div>
            }
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="d-flex gap-2 mt-4">
            <input type="submit" value="تحديث" class="btn btn-primary"
                       style="width:auto" />
                <a asp-action="Index" asp-route-id="@ViewBag.userId"
                   class="btn btn-primary" style="width:auto">الغاء</a>
            </div>
        </form>
    </div>
