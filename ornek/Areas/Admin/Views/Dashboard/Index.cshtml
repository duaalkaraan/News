<h2 class="mb-4">مرحباً بك في لوحة التحكم 👋</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">📰 الأخبار</h5>
                <p class="card-text fs-3">@ViewBag.NewsCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">📁 التصنيفات</h5>
                <p class="card-text fs-3">@ViewBag.CategoryCount</p>
            </div>
        </div>
    </div>
</div>