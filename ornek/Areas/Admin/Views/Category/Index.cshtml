@model List<ornek.Models.Category>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>التصنيفات</h2>
    <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn btn-primary">+ إضافة تصنيف جديد</a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>الاسم</th>
            <th>الإجراءات</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Id</td>
                <td>@category.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-warning">تعديل</a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
        }
    </tbody>
</table>




