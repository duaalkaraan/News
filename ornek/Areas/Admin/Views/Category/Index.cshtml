@model List<ornek.Models.Category>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="section-title mb-0">التصنيفات</h2>
    <a asp-area="Admin" asp-controller="Category" asp-action="Create" class="btn"
           style="background-color: var(--blue-main); color: white; border-radius: 8px; font-weight: 600;">
        + إضافة تصنيف جديد
    </a>
</div>

<div class="card border-0 shadow-sm rounded-3 overflow-hidden">
    <table class="table table-hover mb-0">
        <thead style="background-color: var(--blue-dark); color: white;">
            <tr>
                <th>#</th>
                <th>الاسم</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td class="text-muted">@category.Id</td>
                    <td>@category.Name</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@category.Id"
                           class="btn btn-sm"
                           style="background-color: var(--blue-mid); color: white;">تعديل</a>
                        <a asp-action="Delete" asp-route-id="@category.Id"
                           class="btn btn-sm btn-danger">حذف</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>


