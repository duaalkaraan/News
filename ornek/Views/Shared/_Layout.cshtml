 <!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ornek</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

</head>


<body>

<nav class="navbar navbar-expand-lg px-4">
   
        <ul class="navbar-nav me-auto">
            <li class="nav-item">
                <a class="nav-link" asp-controller="Home" asp-action="Index">الرئيسية</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/#سياسة">سياسة</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/#رياضة">رياضة</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/#تقنية">تقنية</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/#اقتصاد">اقتصاد</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/#ترفيه">ترفيه</a>
            </li>
        </ul>



    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
            <li class="nav-item">
                   

                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="News" asp-action="Index">لوحة التحكم</a>
                        </li>
                    }


                    @if (User.IsInRole("Editor"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Editor" asp-action="Index">نشر خبر</a>
                        </li>
                    }

            </li>
        </ul>

            <ul class="navbar-nav  me-auto">
                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <span class="nav-link"> @User.Identity.Name</span>
                    </li>
                    <li class="nav-item">
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                            <button type="submit" class="btn px-4 py-2 ms-3"
                                    style="background-color: var(--blue-main); color: white; border-radius: 20px;">
                                تسجيل الخروج
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn px-4 py-2 ms-3"
                           style="background-color: var(--blue-main); color: white; border-radius: 20px;"
                           asp-area="Identity" asp-page="/Account/Login"> تسجيل الدخول </a>
                    </li>
                }
            </ul>
    </div>
</nav>
<main>
    @RenderBody()
</main>

<footer class="text-white text-center py-4 mt-5">
    <small>&copy; 2026 ornek — جميع الحقوق محفوظة.</small>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>


