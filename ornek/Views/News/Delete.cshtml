@model ornek.Models.News
@{
    Layout = null;
}
<div class="modal fade" id="deleteModal-@Model.Id" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold text-danger">🗑️ تأكيد الحذف</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p>هل أنت متأكد من حذف هذا الخبر؟</p>
                <p class="fw-bold">@Model.Title</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-3">
                <button type="button" class="btn btn-outline-secondary px-4"
                        data-bs-dismiss="modal">
                    إلغاء
                </button>
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger px-4">نعم، احذف</button>
                </form>
            </div>
        </div>
    </div>
</div>