@model List<ornek.Models.News>

@{
    ViewData["Title"] = "الأخبار";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center mx-3 mt-3">
        ⚠️ @TempData["Error"]
    </div>
}  


<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📰 آخر الأخبار</h2>
        <button type="button" class="btn btn-dark px-4"
                data-bs-toggle="modal" data-bs-target="#addNewsModal">
            + إضافة خبر
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state text-center py-5">
            <div style="font-size:48px">📭</div>
            <h5 class="mt-3 text-muted">لا توجد أخبار بعد</h5>
            <p class="text-muted">كوني أول من ينشر خبراً!</p>
        </div>
    }

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="news-card">
                    <div class="news-card-body">
                        <h5 class="news-title">@item.Title</h5>
                        <p class="news-content">@item.Content</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="news-meta">
                                🕒 @item.CreatedAt.ToString("dd/MM/yyyy — HH:mm")
                            </div>
                            <div class="d-flex gap-2">
                                <!-- زر تعديل -->
                                <button class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editModal-@item.Id">
                                    ✏️ تعديل
                                </button>
                                <!-- زر حذف -->
                                <button class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal-@item.Id">
                                    🗑️ حذف
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal تعديل -->
            <div class="modal fade" id="editModal-@item.Id" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header border-0">
                            <h5 class="modal-title fw-bold">✏️ تعديل الخبر</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="Edit" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">العنوان</label>
                                    <input name="title" class="form-control form-control-lg"
                                           value="@item.Title" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">المحتوى</label>
                                    <textarea name="content" class="form-control"
                                              rows="5" required9>@item.Content</textarea>
                                </div>
                            </div>
                            <div class="modal-footer border-0">
                                <button type="button" class="btn btn-outline-secondary px-4"
                                        data-bs-dismiss="modal">
                                    إلغاء
                                </button>
                                <button type="submit" class="btn btn-dark px-4">
                                    حفظ التعديلات ✓
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal تأكيد الحذف -->
            <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header border-0">
                            <h5 class="modal-title fw-bold text-danger">🗑️ تأكيد الحذف</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center py-4">
                            <div style="font-size:48px">⚠️</div>
                            <p class="mt-3 mb-1">هل أنت متأكد من حذف هذا الخبر؟</p>
                            <p class="fw-bold">@item.Title</p>
                            <p class="text-muted small">لا يمكن التراجع عن هذا الإجراء.</p>
                        </div>
                        <div class="modal-footer border-0 justify-content-center gap-3">
                            <button type="button" class="btn btn-outline-secondary px-4"
                                    data-bs-dismiss="modal">
                                إلغاء
                            </button>
                            <form asp-action="Delete" method="post">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger px-4">
                                    نعم، احذف ✓
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal إضافة خبر جديد -->
<div class="modal fade" id="addNewsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">✏️ إضافة خبر جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body pt-2">
                    <div class="mb-3">
                        <label class="form-label fw-bold">العنوان</label>
                        <input name="Title" class="form-control form-control-lg"
                               placeholder=" عنوان الخبر..." required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">المحتوى</label>
                        <textarea name="Content" class="form-control" rows="5"
                                  placeholder=" تفاصيل الخبر..." required></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary px-4"
                            data-bs-dismiss="modal">
                        إلغاء
                    </button>
                    <button type="submit" class="btn btn-dark px-4">
                        نشر الخبر ✓
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>