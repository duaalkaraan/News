@model List<ornek.Models.News>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "إدارة الأخبار";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center mx-3 mt-3">
        ⚠️ @TempData["Error"]
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center mx-3 mt-3">
        ✅ @TempData["Success"]
    </div>
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📰 إدارة الأخبار</h2>
        <button type="button" class="btn btn-dark px-4"
                data-bs-toggle="modal" data-bs-target="#addNewsModal">
            + إضافة خبر
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:48px">📭</div>
            <h5 class="mt-3 text-muted">لا توجد أخبار بعد</h5>
        </div>
    }

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-12">
                <div class="news-card">
                    <div class="news-card-body">
                        <span class="badge bg-dark mb-2">@item.Category?.Name</span>
                        <h5 class="news-title">@item.Title</h5>

                        @if (item.Images != null && item.Images.Any())
                        {
                            <div class="d-flex gap-2 flex-wrap mb-2">
                                @foreach (var img in item.Images)
                                {
                                    <img src="@img.ImagePath"
                                         style="width:120px;height:80px;object-fit:cover;border-radius:8px;" />
                                }
                            </div>
                        }

                        <p class="news-content">@item.Content</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="news-meta">
                                🕒 @item.CreatedAt.ToString("dd/MM/yyyy — HH:mm")
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editModal-@item.Id">
                                    ✏️ تعديل
                                </button>
                                <button class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal-@item.Id">
                                    🗑️ حذف
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal تعديل -->
            <div class="modal fade" id="editModal-@item.Id" tabindex="-1">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header border-0">
                            <h5 class="modal-title fw-bold">✏️ تعديل الخبر</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form class="edit-form" asp-action="Edit" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="id" value="@item.Id" />
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">العنوان</label>
                                    <input name="title" class="form-control form-control-lg"
                                           value="@item.Title" />
                                    <span class="val-error text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">المحتوى</label>
                                    <textarea name="content" class="form-control"
                                              rows="5">@item.Content</textarea>
                                    <span class="val-error text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">التصنيف</label>
                                    <select name="categoryId" class="form-select">
                                        <option value="">-- اختر التصنيف --</option>
                                        @foreach (var cat in ViewBag.Categories as IEnumerable<SelectListItem>
                                                                                                                                  ?? Enumerable.Empty<SelectListItem>())
                                        {
                                            @if (cat.Value == item.CategoryId.ToString())
                                            {
                                                <option value="@cat.Value" selected>@cat.Text</option>
                                            }
                                            else
                                            {
                                                <option value="@cat.Value">@cat.Text</option>
                                            }
                                        }
                                    </select>
                                    <span class="val-error text-danger small"></span>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">إضافة صور جديدة</label>
                                <label class="btn btn-outline-secondary w-100" style="cursor:pointer">
                                    📎 اختر الصور
                                    <input type="file" name="newImages" multiple accept="image/*"
                                           style="display:none" />
                                </label>
                            </div>
                            <div class="modal-footer border-0">
                                <button type="button" class="btn btn-outline-secondary px-4"
                                        data-bs-dismiss="modal">
                                    إلغاء
                                </button>
                                <button type="submit" class="btn btn-dark px-4">
                                    حفظ التعديلات ✓
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Modal حذف -->
            <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header border-0">
                            <h5 class="modal-title fw-bold text-danger">🗑️ تأكيد الحذف</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center py-4">
                            <div style="font-size:48px">⚠️</div>
                            <p class="mt-3 mb-1">هل أنت متأكد من حذف هذا الخبر؟</p>
                            <p class="fw-bold">@item.Title</p>
                        </div>
                        <div class="modal-footer border-0 justify-content-center gap-3">
                            <button type="button" class="btn btn-outline-secondary px-4"
                                    data-bs-dismiss="modal">
                                إلغاء
                            </button>
                            <form asp-action="Delete" method="post">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger px-4">
                                    نعم، احذف ✓
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal إضافة -->
<div class="modal fade" id="addNewsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">✏️ إضافة خبر جديد</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="createForm" asp-action="Create" method="post"
                  enctype="multipart/form-data">
                <div class="modal-body pt-2">
                    <div class="mb-3">
                        <label class="form-label fw-bold">العنوان</label>
                        <input name="Title" class="form-control form-control-lg"
                               placeholder="عنوان الخبر..." />
                        <span id="titleError" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">المحتوى</label>
                        <textarea name="Content" class="form-control" rows="5"
                                  placeholder="تفاصيل الخبر..."></textarea>
                        <span id="contentError" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">التصنيف</label>
                        <select name="CategoryId" class="form-select">
                            <option value="">-- اختر التصنيف --</option>
                            @foreach (var cat in ViewBag.Categories as IEnumerable<SelectListItem>
                                                                                              ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@cat.Value">@cat.Text</option>
                            }
                        </select>
                        <span id="categoryError" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">الصور</label>
                        <label class="btn btn-outline-secondary w-100" style="cursor:pointer">
                            📎 اختر الصور
                            <input type="file" name="images" multiple accept="image/*"
                                   style="display:none" />
                        </label>
                        <small class="text-muted">يمكنك اختيار أكثر من صورة</small>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary px-4"
                            data-bs-dismiss="modal">
                        إلغاء
                    </button>
                    <button type="submit" class="btn btn-dark px-4">
                        نشر الخبر ✓
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('createForm').addEventListener('submit', function (e) {
        let valid = true;

        const title = this.querySelector('[name="Title"]');
        const content = this.querySelector('[name="Content"]');
        const category = this.querySelector('[name="CategoryId"]');

        document.getElementById('titleError').textContent = '';
        document.getElementById('contentError').textContent = '';
        document.getElementById('categoryError').textContent = '';

        if (!title.value.trim()) {
            document.getElementById('titleError').textContent = '⚠️ العنوان مطلوب';
            valid = false;
        }
        if (!content.value.trim()) {
            document.getElementById('contentError').textContent = '⚠️ المحتوى مطلوب';
            valid = false;
        }
        if (!category.value) {
            document.getElementById('categoryError').textContent = '⚠️ التصنيف مطلوب';
            valid = false;
        }

        if (!valid) e.preventDefault();
    });

    document.querySelectorAll('.edit-form').forEach(function (form) {
        form.addEventListener('submit', function (e) {
            let valid = true;
            const errors = this.querySelectorAll('.val-error');
            errors.forEach(el => el.textContent = '');

            const title = this.querySelector('[name="title"]');
            const content = this.querySelector('[name="content"]');
            const category = this.querySelector('[name="categoryId"]');

            if (!title.value.trim()) {
                errors[0].textContent = '⚠️ العنوان مطلوب';
                valid = false;
            }
            if (!content.value.trim()) {
                errors[1].textContent = '⚠️ المحتوى مطلوب';
                valid = false;
            }
            if (!category.value) {
                errors[2].textContent = '⚠️ التصنيف مطلوب';
                valid = false;
            }

            if (!valid) e.preventDefault();
        });
    });
</script>